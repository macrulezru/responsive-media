{
  "name": "responsive-media",
  "version": "1.2.6",
  "description": "Reactive state from CSS media and container queries — breakpoint helpers, AND/OR conditions and CSS-var sync, SSR-safe. Vanilla JS / Vue 3 / React.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react-responsive.d.ts",
      "import": "./dist/react-responsive.js",
      "require": "./dist/react-responsive.js"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js",
      "require": "./dist/presets.js"
    },
    "./container": {
      "types": "./dist/container-state.d.ts",
      "import": "./dist/container-state.js",
      "require": "./dist/container-state.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macrulezru/responsive-media.git"
  },
  "homepage": "https://github.com/macrulezru/responsive-media#readme",
  "bugs": {
    "url": "https://github.com/macrulezru/responsive-media/issues"
  },
  "keywords": [
    "responsive",
    "media-query",
    "container-query",
    "breakpoints",
    "reactive",
    "ssr",
    "vue",
    "vue3",
    "react",
    "typescript"
  ],
  "author": "macrulez <macrulezru@gmail.com> (https://macrulez.ru/en)",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/vue": "^1.0.31",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "vue": "^3.5.34"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "vue": "^3.5.27"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
